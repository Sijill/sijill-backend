{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": "..",
	"testEnvironment": "node",
	"testRegex": "test/.*\\.e2e-spec\\.ts$",
	"transform": {
		"^.+\\.(t|j)s$": "ts-jest"
	},
	"moduleNameMapper": {
		"^@db/(.*)$": "<rootDir>/src/modules/database/$1",
		"^@email/(.*)$": "<rootDir>/src/modules/email/$1",
		"^@modules/(.*)$": "<rootDir>/src/modules/$1",
		"^@guards/(.*)$": "<rootDir>/src/modules/auth/guards/$1",
		"^@helpers/(.*)$": "<rootDir>/src/common/helpers/$1",
		"^@common/(.*)$": "<rootDir>/src/common/$1",
		"^@uploads$": "<rootDir>/uploads",
		"^uuid$": "<rootDir>/test/mocks/uuid.ts"
	}
}
